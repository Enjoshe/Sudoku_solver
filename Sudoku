# verify.py
# Sudoku LLM Solution Verifier

def is_valid_group(nums):
    """Check if a group contains digits 1–9 exactly once."""
    return sorted(nums) == list(range(1, 10))


def verify_sudoku(grid):
    """
    Verifies a 9x9 Sudoku grid.
    Returns: (bool, message)
    """

    # -----------------------
    # 1. Check rows
    # -----------------------
    for i in range(9):
        row = grid[i]
        if not is_valid_group(row):
            return False, f"Invalid row at index {i + 1}"

    # -----------------------
    # 2. Check columns
    # -----------------------
    for j in range(9):
        col = [grid[i][j] for i in range(9)]
        if not is_valid_group(col):
            return False, f"Invalid column at index {j + 1}"

    # -----------------------
    # 3. Check 3x3 subgrids
    # -----------------------
    for row_start in range(0, 9, 3):
        for col_start in range(0, 9, 3):
            box = []
            for i in range(3):
                for j in range(3):
                    box.append(grid[row_start + i][col_start + j])

            if not is_valid_group(box):
                return False, f"Invalid 3x3 box starting at ({row_start+1},{col_start+1})"

    return True, "Valid Sudoku solution"


def parse_grid(input_str):
    """
    Converts multiline string into 9x9 integer grid.
    Accepts space-separated rows.
    """
    lines = input_str.strip().split("\n")
    grid = []

    for line in lines:
        row = list(map(int, line.strip().split()))
        if len(row) != 9:
            raise ValueError("Each row must contain exactly 9 numbers.")
        grid.append(row)

    if len(grid) != 9:
        raise ValueError("Grid must contain exactly 9 rows.")

    return grid


def main():
    print("Enter Sudoku solution (9 lines, each with 9 numbers):")
    print("Example: 5 3 4 6 7 8 9 1 2\n")

    user_input = ""
    for _ in range(9):
        user_input += input() + "\n"

    try:
        grid = parse_grid(user_input)
    except Exception as e:
        print("Input Error:", e)
        return

    valid, message = verify_sudoku(grid)

    print("\nRESULT:")
    print(message)

    if valid:
        print("✔ Sudoku is correct")
    else:
        print("✘ Sudoku is incorrect")


if __name__ == "__main__":
    main()
